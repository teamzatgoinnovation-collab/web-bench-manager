# Bench Manager — local ops console only. Never expose publicly.
#
# Required:
#   BENCH_MANAGER_TOKEN   shared secret for the login gate
#
# Optional:
#   WORKSPACE_ROOT        absolute path to ZatGo WorkSpace (auto-detected if unset)
#   ALLOW_INSECURE_DEV_TOKEN=1  uses a documented placeholder token (dev only)

BENCH_MANAGER_TOKEN=
ALLOW_INSECURE_DEV_TOKEN=1
# WORKSPACE_ROOT=/home/agaib/ZatGoInnovation/WorkSpace

# --- DigitalOcean (Cloud env) — SSH then docker exec ---
# Prefer Settings UI (data/settings.json). Env is fallback; default host 157.230.8.164.
# Key path must be absolute and under $HOME/.ssh/
DO_SSH_HOST=157.230.8.164
DO_SSH_USER=root
DO_SSH_PORT=22
DO_SSH_KEY_PATH=/home/YOU/.ssh/id_ed25519
# Optional: skip discovery
# DO_BACKEND_CONTAINER=frappe_docker-backend-1
# Required for Manual → new-site on DigitalOcean
# DO_DB_ROOT_PASSWORD=

# Local new-site
# LOCAL_DB_ROOT_PASSWORD=
